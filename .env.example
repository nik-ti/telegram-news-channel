# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_CHANNEL_ID=-1001234567890
MAIN_CHANNEL_ID=-1001234567891
TELEGRAM_ERROR_BOT_TOKEN=optional_fallback_token
TELEGRAM_ERROR_CHAT_ID=optional_fallback_chat_id

# Notion
NOTION_API_KEY=secret_xxx
NOTION_DATABASE_ID=xxx-xxx-xxx

# OpenRouter (LLM API)
OPENROUTER_API_KEY=sk-or-v1-xxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# Webhook
WEBHOOK_HOST=https://your-domain.com
WEBHOOK_PATH=/news_webhook
WEBHOOK_PORT=8082

# Scheduling
CRON_INTERVAL_MINUTES=60

# Optional proxy for blocked sources
# PROXY_SERVER=proxy.example.com
# PROXY_PORT=8080
# PROXY_USERNAME=user
# PROXY_PASSWORD=pass

# Misc
LOG_LEVEL=INFO
DATA_DIR=./data
SAFE_MODE=false
